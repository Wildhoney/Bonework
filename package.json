{
  "name": "react-native-bone-skeleton",
  "version": "0.1.0",
  "description": "Thin, colour-aware skeleton loader for React Native — themed wrapper around react-native-reanimated-skeleton.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "main": "./dist/skeleton.cjs",
  "module": "./dist/skeleton.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/skeleton.js",
      "require": "./dist/skeleton.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:example": "vite build --mode example --base /Skeleton/ && mv dist-example/src/example/index.html dist-example/index.html && rm -rf dist-example/src",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "fmt": "prettier --write .",
    "release": "make checks",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "react-native",
    "skeleton",
    "loader",
    "placeholder",
    "shimmer",
    "loading"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wildhoney/Skeleton.git"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74"
  },
  "dependencies": {
    "react-native-reanimated-skeleton": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.1",
    "commit-and-tag-version": "^12.6.1",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "0.76.5",
    "react-native-web": "^0.19.13",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^5.4.5",
    "vite-plugin-dts": "^4.2.1",
    "vitest": "^2.1.1"
  }
}
